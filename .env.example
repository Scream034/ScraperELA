# ============================================================
# ScraperELA — шаблон переменных окружения
# ============================================================
# Скопируйте этот файл в .env и заполните реальными значениями:
#   cp .env.example .env
#
# Файл .env добавлен в .gitignore и никогда не попадёт в репозиторий.
# ============================================================

# --- DaData (первичный провайдер обогащения) ----------------
# Получить ключи: https://dadata.ru/profile/#info
DADATA_API_KEY=
DADATA_SECRET_KEY=

# --- Настройки парсера (опционально переопределить) ---------
# ACTIVE_SITE=chop_moscow
# REQUEST_DELAY=0.5