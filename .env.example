# =====================================================================
# ScraperELA · Конфигурация среды (.env)
# =====================================================================
# Скопируйте этот файл в .env и настройте под свои нужды.
# Изменения в .env не отслеживаются Git, что предотвращает случайный коммит паролей.
# =====================================================================

# ---------------------------------------------------------------------
# 1. РЕЖИМЫ ЗАПУСКА (True | False)
# ---------------------------------------------------------------------
# RUN_CATALOG_SCAN - сканировать страницы каталогов и наполнять очередь
RUN_CATALOG_SCAN=False
# Сканирует website каждой компании в поисках email и телефонов
RUN_WEBSITE_CONTACT_SCAN=False
# RUN_DETAIL_PARSER - парсить детальные карточки из очереди
RUN_DETAIL_PARSER=False
# RUN_ENRICHMENT - запускать обогащение по ИНН через DaData / ФНС
RUN_ENRICHMENT=True
# RUN_EXPORTER - генерировать XLSX отчет на выходе
RUN_EXPORTER=True

# ---------------------------------------------------------------------
# 2. ИСТОЧНИКИ ДАННЫХ
# ---------------------------------------------------------------------
# ACTIVE_SITE - список сайтов для обработки (через запятую без пробелов)
# Доступные: chop_moscow, prochop_ru, vsechopy_mo, vsechopy_urfo
ACTIVE_SITE=chop_moscow

# MAX_CONCURRENT_SITES - сколько сайтов обрабатывать параллельно
MAX_CONCURRENT_SITES=4

# ---------------------------------------------------------------------
# 3. НАСТРОЙКИ СЕТИ И ТРОТТЛИНГА
# ---------------------------------------------------------------------
# REQUEST_DELAY - базовый интервал между запросами к одному сайту (сек)
REQUEST_DELAY=0.5
# NETWORK_RETRIES - количество повторных попыток при сетевой ошибке
NETWORK_RETRIES=5
# BACKOFF_FACTOR - множитель задержки при повторных попытках
BACKOFF_FACTOR=1.0

# ADAPTIVE_MODE - динамическая регулировка задержек при ошибках (True | False)
ADAPTIVE_MODE=True
# ADAPTIVE_MAX_DELAY - максимальная задержка при жестком троттлинге (сек)
ADAPTIVE_MAX_DELAY=10.0

# ---------------------------------------------------------------------
# 4. КЭШИРОВАНИЕ HTML
# ---------------------------------------------------------------------
USE_HTML_CACHE=True
CACHE_TTL_DAYS=28
KEEP_CACHE_HISTORY=True

# ---------------------------------------------------------------------
# 5. НАСТРОЙКИ ОБОГАЩЕНИЯ (ENRICHMENT)
# ---------------------------------------------------------------------
# DADATA_API_KEY - Токен API DaData (для ЕГРЮЛ верификации)
# DADATA_SECRET_KEY - Секретный ключ DaData
# Оставьте пустыми, если хотите использовать только бесплатный ФНС-парсер
DADATA_API_KEY=
DADATA_SECRET_KEY=

# DADATA_DAILY_LIMIT - жесткий лимит запросов в сутки к DaData
DADATA_DAILY_LIMIT=10000
# FNS_REQUEST_DELAY - задержка между запросами к публичному API ФНС (сек)
FNS_REQUEST_DELAY=2.0

# ENRICHMENT_BATCH_SIZE - сколько ИНН проверять за один запуск фазы обогащения
# Установите в 1, если хотите протестировать работу на одной записи!
ENRICHMENT_BATCH_SIZE=500

# ENRICHMENT_RECHECK_DAYS - период действия верификации (TTL).
# Организации не будут повторно обогащаться, если они проверялись менее N дней назад.
ENRICHMENT_RECHECK_DAYS=28

# Фильтры для фазы обогащения (позволяют экономить лимиты, не проверяя всё подряд)
# Оставьте пустыми (не заполняйте значение), чтобы отключить фильтр
ENRICHMENT_FILTER_CITY=Москва
ENRICHMENT_FILTER_SITE_KEY=

# ---------------------------------------------------------------------
# 6. НАСТРОЙКИ ЭКСПОРТА (XLSX)
# ---------------------------------------------------------------------
EXPORT_TO_XLSX=True
EXPORT_TO_CSV=False

# EXPORT_LIMIT - Максимальное количество строк в XLSX файле (0 - без лимита)
EXPORT_LIMIT=1

# EXPORT_SORT_BY - Сортировка экспорта в формате поле:НАПРАВЛЕНИЕ.
# Доступные поля: name, inn, address, director, scrape_date, last_seen_at, status_official, source_count
# Доступные направления: ASC, DESC
EXPORT_SORT_BY=name:ASC

# Фильтры выгрузки в XLSX
EXPORT_FILTER_CITY=Москва
EXPORT_FILTER_SITE_KEY=
# Варианты: ACTIVE | LIQUIDATED | LIQUIDATING | BANKRUPT | REORGANIZING
EXPORT_FILTER_STATUS_OFFICIAL=
EXPORT_FILTER_HAS_INN=False
EXPORT_FILTER_HAS_PHONE=False

# ---------------------------------------------------------------------
# 7. ДИАГНОСТИКА
# ---------------------------------------------------------------------
# LOG_LEVEL - уровень детализации логов (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ---------------------------------------------------------------------
# 8. СКАНИРОВАНИЕ САЙТОВ КОМПАНИЙ
# ---------------------------------------------------------------------
# Одновременно сканируемых сайтов
WEBSITE_SCAN_CONCURRENCY=5
# Задержка между сайтами (сек)
WEBSITE_SCAN_DELAY=1.0
# Таймаут HTTP-запроса к сайту (сек)
WEBSITE_SCAN_TIMEOUT=15.0
# Максимум страниц на один сайт (главная + контакты + ...)
WEBSITE_SCAN_MAX_PAGES=4
# 0 = сканировать все компании по фильтрам (0 = все)
WEBSITE_SCAN_BATCH_SIZE=0

# Фильтры сканирования сайтов
# Город — сканировать только компании с адресом в этом городе
WEBSITE_SCAN_FILTER_CITY=Москва
# Источник — сканировать только компании из этого каталога
WEBSITE_SCAN_FILTER_SITE_KEY=
# Статус ФНС — например ACTIVE (только действующие)
# Пусто = без ограничений
WEBSITE_SCAN_FILTER_STATUS_OFFICIAL=
# True = только компании без email (экономит время при повторных запусках)
# False = все компании с website
WEBSITE_SCAN_FILTER_ONLY_WITHOUT_EMAIL=True
