{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ScraperELA: DEBUG (Подробные логи)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "LOG_LEVEL": "DEBUG"
            }
        },
        {
            "name": "ScraperELA: RELEASE (Быстрый запуск)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "pythonArgs": ["-O"],
            "env": {
                "LOG_LEVEL": "WARNING"
            }
        }
    ]
}